        "jsCode": "const nuevos = $items(\"Transformamos en Json\");\nconst existentes = $items(\"Comprobar guardados\");\n\n// messageId ya guardados\nconst idsExistentes = new Set(\n  existentes\n    .map(item => (item.json.messageId || \"\").trim())\n    .filter(Boolean)\n);\n\n// solo deja pasar los nuevos\nreturn nuevos.filter(item => {\n  const id = (item.json.messageId || \"\").trim();\n  return id && !idsExistentes.has(id);\n});"
