    {
      "parameters": {
        "jsCode": "const validados = $items(\"Validar médico\");\n\nreturn items.map((item, index) => {\n  const raw = item.json.content?.parts?.[0]?.text || \"\";\n\n  if (!raw) {\n    throw new Error(`No se encontró texto en la respuesta de la IA para el item ${index}`);\n  }\n\n  let parsed;\n\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    throw new Error(`La respuesta de la IA no es JSON válido en el item ${index}: ${raw}`);\n  }\n\n  const previo = validados[index]?.json || {};\n\n  return {\n    json: {\n      medico_id: previo.medico_id || \"\",\n      nombre_medico: previo.nombre_medico || \"\",\n      email_medico: previo.email_medico || \"\",\n      remitente_email: previo.remitente_email || \"\",\n      subject: previo.subject || \"\",\n      messageId: previo.messageId || \"\",\n      inReplyTo: previo.inReplyTo || \"\",\n      references: previo.references || \"\",\n      date: previo.date || \"\",\n      texto_limpio: previo.texto_limpio || \"\",\n      validado: previo.validado || false,\n\n      no_puedo: parsed.no_puedo || [],\n      preferiria_librar: parsed.preferiria_librar || [],\n      prefiere_guardia: parsed.prefiere_guardia || [],\n      dobletes: parsed.dobletes || [],\n      rotacion: parsed.rotacion || \"\",\n      rotacion_externa: parsed.rotacion_externa ?? false,\n      restricciones: parsed.restricciones || [],\n      observaciones: parsed.observaciones || \"\"\n    }\n  };\n});"
      },
