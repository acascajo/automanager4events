    {
      "parameters": {
        "jsCode": "const itemsEdit = $items(\"Edit Fields\");\nconst itemsFilter = $items(\"Filter\");\n\nif (!itemsEdit.length) {\n  throw new Error(\"No hay datos en Edit Fields\");\n}\n\nconst periodo = itemsEdit[0].json;\n\nconst resultado = itemsFilter.map(item => {\n  return {\n    json: {\n      medico_id: item.json.medico_id,\n      nombre: item.json.nombre,\n      email: item.json.email,\n      activo: item.json.activo,\n      periodo_label: periodo.periodo_label,\n      fecha_inicio_periodo: periodo.fecha_inicio_periodo,\n      fecha_fin_periodo: periodo.fecha_fin_periodo,\n      fecha_limite_respuesta: periodo.fecha_limite_respuesta\n    }\n  };\n});\n\nreturn resultado;"
      },
